{
  "require": {
    "nikic/php-parser": "^5.6",
    "phpunit/phpunit": "^11"
  },
  "replace": {
    "herrera-io/json": "*"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/",
      "Parser\\": "src/Parser/",
      "Util\\": "src/Util/",
      "Generator\\": "src/Generator/",
      "Analyser\\": "src/Analyser/"
    }
  },

  "scripts": {
    "docgen": "php bin/run.php",
    "test": "vendor/bin/phpunit",
    "phpdoc": "php phpdoc.phar run -c phpdoc.xml"
  }
}
